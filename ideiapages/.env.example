# =====================================================
# IDeiaPages - Variáveis de Ambiente
# =====================================================
# Copie este arquivo para .env e preencha os valores
# NUNCA commite .env real

# -----------------------------------------------------
# Supabase
# -----------------------------------------------------
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxx

# Para o app Next.js (apenas anon vai pro client)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxx

# -----------------------------------------------------
# APIs de Pesquisa
# -----------------------------------------------------
APIFY_TOKEN=apify_api_xxxxx
FIRECRAWL_API_KEY=fc-xxxxx

# Imagens no blog (hero + destaque no artigo) — servidor apenas, não expor no client
# https://www.pexels.com/api/
PEXELS_API_KEY=

# -----------------------------------------------------
# LLMs
# -----------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxxxx
OPENAI_API_KEY=sk-xxxxx
GOOGLE_AI_API_KEY=xxxxx
# Alias aceito no código de geração Gemini:
# GEMINI_API_KEY=xxxxx

# Modelos (opcional; defaults no código)
# CLAUDE_MODEL=claude-sonnet-4-20250514
# CLAUDE_SEED_MODEL=claude-haiku-4-5-20251001
# (Haiku para /api/admin/research/suggest-seeds — alias: claude-haiku-4-5)
# OPENAI_MODEL=gpt-4o-mini
# GEMINI_MODEL=gemini-2.0-flash

# -----------------------------------------------------
# Admin / Dashboard (Fase 3)
# -----------------------------------------------------
# E-mails permitidos em /admin/* (minúsculas, separados por vírgula)
ADMIN_ALLOWED_EMAILS=operador@seudominio.com.br

# Opcional no dev: forçar login (por padrão, em `pnpm dev` o admin já abre sem Magic Link)
# ADMIN_LOCAL_BYPASS=false
#
# Permitir disparar pipeline e coletas (CLI Python) a partir do painel /admin/research
# em servidores que tenham `uv` e o módulo research (não use na Vercel). Em pnpm dev já funciona.
# ALLOW_ADMIN_RESEARCH_CLI=1
#
# Pesquisa — Google Trends (CLI ideiapages-research): proxy de volume mensal em termos.volume_estimado.
# Índice médio 12m (0–100) × (PYTRENDS_VOLUME_PROXY_MAX / 100). Default 10000.
# PYTRENDS_VOLUME_PROXY_MAX=10000
#
# Gerar sementes a partir da URL (Firecrawl + Claude no Next): FIRECRAWL_API_KEY + ANTHROPIC_API_KEY.
# O Next (web/) carrega também o .env da pasta pai ideiapages/ — podes manter um único .env na raiz.
#
# Autocura (Fase 4) — crons e sync GSC em background
# UUID do admin que já concluiu OAuth GSC (mesma conta com acesso à propriedade):
# GSC_SYNC_USER_ID=
# Propriedade exatamente como na GSC (barra final para prefixo de URL):
# GSC_SITE_URL=https://seusite.com.br/
# Protege GET /api/cron/* — deve coincidir com o segredo de Cron na Vercel:
# CRON_SECRET=
# Janela de dias a sincronizar (default 28):
# GSC_SYNC_DAYS_BACK=28
# Limites e custo estimado do worker (BRL):
# AUTOMATION_PIPELINE_ESTIMATE_BRL=12
# USD_TO_BRL=5.5
# IAs na regeneração automática (vírgula):
# AUTOMATION_REWRITE_PROVIDERS=claude,gpt

# Search Console (importar consultas no /admin/research) — OAuth 2.0:
# 1) Google Cloud Console: ativar "Google Search Console API"; criar credenciais OAuth (tipo Web).
# 2) URIs de redirecionamento autorizados (exemplos):
#    http://localhost:3000/api/admin/gsc/oauth-callback
#    https://SEU_DOMINIO/api/admin/gsc/oauth-callback
# 3) A variável NEXT_PUBLIC_SITE_URL (abaixo) deve bater com o host usado nesses URIs.
# GOOGLE_OAUTH_CLIENT_ID=xxxxx.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=xxxxx
# Opcional: assinatura do parâmetro state (se não existir, usa o service role — menos ideal).
# GSC_OAUTH_STATE_SECRET=um_segreto_aleatorio_longo

# -----------------------------------------------------
# GEO — visibilidade em motores generativos (dashboard)
# -----------------------------------------------------
# Não requer chaves: o registo de checks é via sessão admin (POST) ou script com service role.
# Corpo: { "check": { "pagina_id": "<uuid>", "engine": "perplexity", "mentioned": true } }
# ou    { "checks": [ { ... } ] } — ver /api/admin/generative-visibility
# Aplica a migração 0015_generative_visibility_checks no Supabase antes de inserir.

# -----------------------------------------------------
# Analytics (no Next.js)
# -----------------------------------------------------
# Preferência: ID usado pelo @next/third-parties (layout.tsx)
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
# Alias legado (também aceito no layout)
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# -----------------------------------------------------
# WhatsApp (CTA)
# -----------------------------------------------------
NEXT_PUBLIC_WHATSAPP_NUMBER=5500000000000
NEXT_PUBLIC_WHATSAPP_DEFAULT_MESSAGE=Olá! Vim do site e quero saber mais.

# -----------------------------------------------------
# Marca pública (blog / rodapé legal — SEO local)
# -----------------------------------------------------
# NEXT_PUBLIC_IDEIA_CNPJ=00.000.000/0001-00
# NEXT_PUBLIC_IDEIA_ADDRESS=Rua Exemplo, 1 — Cidade, UF
# NEXT_PUBLIC_IDEIA_LOGO_URL=https://ideiamultichat.com.br/.../logo.png
# NEXT_PUBLIC_IDEIA_PRIVACY_URL=https://ideiamultichat.com.br/politica-de-privacidade/
# NEXT_PUBLIC_IDEIA_HOME_URL=https://ideiamultichat.com.br/
# NEXT_PUBLIC_IDEIA_INSTAGRAM_URL=https://www.instagram.com/ideiachat/
# NEXT_PUBLIC_IDEIA_WHATSAPP_PUBLIC_URL=https://wa.me/5551995232447
# NEXT_PUBLIC_IDEIA_PHONE_DISPLAY=(51) 99523-2447
# NEXT_PUBLIC_IDEIA_PHONE_TEL=tel:+5551995232447
# NEXT_PUBLIC_IDEIA_BUSINESS_HOURS=De segunda a sexta, das 08h12 às 18h00
# NEXT_PUBLIC_IDEIA_SERVICE_AREA=Atendemos todo o Brasil
# NEXT_PUBLIC_IDEIA_FOOTER_BLURB=Texto curto do rodapé (opcional)

# -----------------------------------------------------
# Outras
# -----------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://ideiamultichat.com.br
# Em produção (Vercel): definir como "production" para GA4 + robots indexáveis
NEXT_PUBLIC_ENV=development
NODE_ENV=development

# Service role: obrigatório em Vercel (server-only) para /api/leads — NUNCA expor no client
# SUPABASE_SERVICE_ROLE_KEY já declarado acima

# Next.js (só se `pnpm dev` não correr a partir de ideiapages/web e o painel precisar do CLI)
# Caminho absoluto da pasta com pyproject (ideiapages/research)
# IDEIAPAGES_RESEARCH_DIR=
